{
  "name": "myai-rag-notebook",
  "version": "1.0.0",
  "description": "\"MyAI\", a RAG-based notebook",
  "main": "index.ts",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsgo --project tsconfig.build.json",
    "format": "prettier --write",
    "format:check": "prettier --check",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsgo --noEmit",
    "start": "nest start --type-check",
    "start:dev": "nest start --watch --type-check",
    "start:debug": "nest start --debug --watch --type-check",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tduyduc/myai-rag-notebook.git"
  },
  "author": "T.D. Stoneheart <tduyduc3@gmail.com>",
  "license": "MIT",
  "private": true,
  "bugs": {
    "url": "https://github.com/tduyduc/myai-rag-notebook/issues"
  },
  "homepage": "https://github.com/tduyduc/myai-rag-notebook#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@tsconfig/node20": "^20.1.9",
    "@tsconfig/strictest": "^2.0.8",
    "@types/eslint": "^9.6.1",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20.19.9",
    "@types/pdf-parse": "^1.1.5",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@lancedb/lancedb": "^0.27.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "fp-ts": "^2.16.11",
    "ky": "^1.14.3",
    "lodash": "^4.18.1",
    "ollama": "^0.6.3",
    "parse-sse": "^0.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ulid": "^3.0.2"
  }
}
